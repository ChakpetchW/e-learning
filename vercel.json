{
  "version": 2,
  "builds": [
    {
      "src": "elearning-api/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "elearning-webapp/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "elearning-api/src/server.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/elearning-webapp/index.html"
    }
  ]
}