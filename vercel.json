{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "dest": "/elearning-api/src/server.js"
    },
    {
      "source": "/(.*)",
      "dest": "/elearning-webapp/"
    }
  ],
  "functions": {
    "elearning-api/src/server.js": {
      "runtime": "vercel-node@latest"
    }
  }
}
