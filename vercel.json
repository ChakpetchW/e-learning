{
  "version": 2,
  "functions": {
    "elearning-api/src/server.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/elearning-api/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/elearning-webapp/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/elearning-webapp/dist/index.html"
    }
  ]
}
