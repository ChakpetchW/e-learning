{
  "version": 2,
  "builds": [
    {
      "src": "elearning-api/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "elearning-webapp/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "elearning-api/src/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "elearning-webapp/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "elearning-webapp/dist/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "elearning-webapp/dist/index.html"
    }
  ]
}