{
  "version": 2,
  "builds": [
    {
      "src": "elearning-api/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "elearning-webapp/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "elearning-api/src/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/elearning-webapp/assets/$1"
    },
    {
      "src": "/((?!api/).*\\.(js|css|png|jpg|svg|ico|webp))",
      "dest": "/elearning-webapp/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/elearning-webapp/index.html"
    }
  ]
}