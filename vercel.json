{
  "version": 2,
  "builds": [
    {
      "src": "elearning-api/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "elearning-webapp/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "dest": "elearning-api/src/server.js"
    },
    {
      "source": "/(.*)",
      "dest": "/elearning-webapp/$1",
      "continue": true
    },
    {
      "source": "/(.*)",
      "dest": "/elearning-webapp/index.html"
    }
  ]
}